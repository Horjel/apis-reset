            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/messages/999999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "messages", "999999"]
            },
            "description": "Caso negativo: no existe un mensaje con ese identificador."
          },
          "response": []
        },
