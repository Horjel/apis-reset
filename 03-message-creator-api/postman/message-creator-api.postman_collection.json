{
  "info": {
    "_postman_id": "9f97e183-04e8-489f-a9b4-a55976f8678f",
    "name": "APIS RESET - 03 Message Creator API",
    "description": "Coleccion para practicar POST, request bodies, variables y casos negativos de HTTP.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "messageId",
      "value": "",
      "type": "string"
    },
    {
      "key": "messageAuthor",
      "value": "",
      "type": "string"
    },
    {
      "key": "messageContent",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Messages",
      "item": [
        {
          "name": "Create message - 201 Created",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json();",
                  "const sentBody = JSON.parse(pm.request.body.raw);",
                  "",
                  "pm.collectionVariables.set(\"messageId\", responseBody.id);",
                  "pm.collectionVariables.set(\"messageAuthor\", responseBody.author);",
                  "pm.collectionVariables.set(\"messageContent\", responseBody.content);",
                  "",
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Created message contains the values sent\", function () {",
                  "    pm.expect(responseBody.id).to.be.a(\"number\").and.to.be.above(0);",
                  "    pm.expect(responseBody.author).to.eql(sentBody.author);",
                  "    pm.expect(responseBody.content).to.eql(sentBody.content);",
                  "});",
                  "",
                  "pm.test(\"Location identifies the created message\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Location\"))",
                  "        .to.eql(\"/api/v1/messages/\" + responseBody.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author\": \"Jorge\",\n  \"content\": \"Estoy aprendiendo APIs REST\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "messages"]
            },
            "description": "Crea un mensaje y guarda su id y sus valores en variables de coleccion."
          },
          "response": []
        },
        {
          "name": "Get created message - 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Response contains the stored message\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.eql(Number(pm.collectionVariables.get(\"messageId\")));",
                  "    pm.expect(body.author).to.eql(pm.collectionVariables.get(\"messageAuthor\"));",
                  "    pm.expect(body.content).to.eql(pm.collectionVariables.get(\"messageContent\"));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/messages/{{messageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "messages", "{{messageId}}"]
            },
            "description": "Consulta el mensaje creado por la peticion anterior usando messageId."
          },
          "response": []
        },
        {
