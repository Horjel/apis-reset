{
  "info": {
    "_postman_id": "c57939cf-835a-44cc-bf0c-5bf63e0c6e62",
    "name": "APIS RESET - 02 Dynamic Greeting API",
    "description": "Coleccion de Postman para practicar path variables y query parameters.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Dynamic greetings",
      "item": [
        {
          "name": "Get formal greeting - 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Formal greeting contains expected values\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.eql(\"Good day, Jorge.\");",
                  "    pm.expect(body.name).to.eql(\"Jorge\");",
                  "    pm.expect(body.formal).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/greetings/Jorge?formal=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "greetings", "Jorge"],
              "query": [
                {
                  "key": "formal",
                  "value": "true"
                }
              ]
            },
            "description": "Caso positivo con path variable y query parameter explicito."
          },
          "response": []
        },
        {
          "name": "Get default informal greeting - 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Default formal value is false\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.eql(\"Hello, Ana!\");",
                  "    pm.expect(body.name).to.eql(\"Ana\");",
                  "    pm.expect(body.formal).to.eql(false);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/greetings/Ana",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "greetings", "Ana"]
            },
            "description": "Caso positivo sin query parameter; formal debe usar false."
          },
          "response": []
        },
        {
          "name": "Get greeting without name - 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 404\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/greetings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "greetings"]
            },
            "description": "Caso negativo: falta la path variable obligatoria name."
          },
          "response": []
        },
        {
          "name": "Get greeting with invalid formal value - 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/greetings/Ana?formal=maybe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "greetings", "Ana"],
              "query": [
                {
                  "key": "formal",
                  "value": "maybe"
                }
              ]
            },
            "description": "Caso negativo: maybe no puede convertirse a boolean."
          },
          "response": []
        }
      ]
    }
  ]
}
